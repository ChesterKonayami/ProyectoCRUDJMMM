@model ProyectoPerritosWCF.Models.AdministracionViewModel
@{
    ViewBag.Title = "Administración";
}

<!-- Panel de Administración -->

<h2>Panel de Administración de Usuarios</h2>

<hr />

@using (Html.BeginForm(
    "Administracion",
    "Home",
    FormMethod.Post))
{
    <script>

        // Limpia un TextBox cuando su valor inicial es 0.
        function limpiarSiEsCero(idControl) {
            var control = document.getElementById(idControl);

            if (control && control.value === "0") {
                control.value = "";
            }
        }

        // Se ejecuta al cargar la página.
        window.onload = function () {
            // Limpiar los campos numéricos.
            limpiarSiEsCero("txtID");
            limpiarSiEsCero("txtEdad");
        };

        // Solo permitir números en la Edad.
        document.getElementById("txtEdad")
            .addEventListener("input", function () {
                this.value =
                    this.value.replace(/[^0-9]/g, "");
            });

    </script>

    <table style="width:100%;">

        <tr>

            <!-- =============== -->
            <!-- Formulario CRUD -->
            <!-- =============== -->

            <td style="width:40%; vertical-align:top;">

                <h3>Formulario de Usuario</h3>

                <!-- Datos de búsqueda-->
                <p>
                    <asp:Label runat="server" Text="Label"></asp:Label>
                    <asp:TextBox runat="server"></asp:TextBox>

                    <label>ID:</label><br />

                    @Html.TextBoxFor(
                            model => model.Usuario.ID_USUARIO,
                            new
                            {
                                 id = "txtID",
                                 placeholder = "Ingrese el ID del usuario",
                                 autocomplete = "off"
                            })

                    <button type="submit"
                            name="accion"
                            value="Consultar">
                        Consultar
                    </button>

                    <br />

                    @if (ViewBag.ErrorID != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorID
                        </span>
                    }



                </p>

                <!-- Datos personales-->
                <p>
                    <label>Nombre:</label><br />

                    @Html.TextBoxFor(
                            model => model.Usuario.NOMBRE,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Ingrese el nombre",
                                maxlength = "50",
                                autocomplete = "off"
                            })
                    <br />

                    @if (ViewBag.ErrorNombre != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorNombre
                        </span>
                    }
                </p>

                <p>
                    <label>Apellido Paterno:</label><br />

                    @Html.TextBoxFor(
                         model => model.Usuario.APELLIDO_PATERNO,
                         new
                         {
                             @class = "form-control",
                             placeholder = "Ingrese el apellido paterno",
                             maxlength = "50",
                             autocomplete = "off"
                         })
                    <br />

                    @if (ViewBag.ErrorApellidoPaterno != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorApellidoPaterno
                        </span>
                    }
                </p>


                <p>
                    <label>Apellido Materno:</label><br />
                    @Html.TextBoxFor(
                            model => model.Usuario.APELLIDO_MATERNO,
                            new
                            {
                                @class = "form-control",
                                placeholder = "Ingrese el apellido materno",
                                maxlength = "50",
                                autocomplete = "off"
                            })
                    <br />

                    @if (ViewBag.ErrorApellidoMaterno != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorApellidoMaterno
                        </span>
                    }
                </p>

                <p>
                    <label>Edad:</label><br />

                    @Html.TextBoxFor(
                        model => model.Usuario.EDAD,
                        new
                        {
                            id = "txtEdad",
                            placeholder = "Ingrese la edad",
                            maxlength = "3",
                            autocomplete = "off"
                        })
                    <br />

                    @if (ViewBag.ErrorEdad != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorEdad
                        </span>
                    }
                </p>

                <p>
                    <label>Género:</label><br />

                    @Html.DropDownListFor(
                        model => model.Usuario.GENERO,
                        new List<SelectListItem>
                        {
                            new SelectListItem
                            {
                                Text = "Seleccione un género",
                                Value = ""
                            },

                            new SelectListItem
                            {
                                Text = "Masculino",
                                Value = "Masculino"
                            },

                            new SelectListItem
                            {
                                Text = "Femenino",
                                Value = "Femenino"
                            }

                        },
                        new
                        {
                            id = "cmbGenero",
                        })

                    <br />

                    @if (ViewBag.ErrorGenero != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorGenero
                        </span>
                    }

                </p>

                <!-- Datos de acceso-->
                <p>
                    <label>Email:</label><br />

                    @Html.TextBoxFor(
                        model => model.Usuario.EMAIL,
                        new
                        {
                            id = "txtEmail",
                            type = "email",
                            placeholder = "Ingrese el correo electrónico",
                            maxlength = "100",
                            autocomplete = "off"
                        })
                    <br />

                    @if (ViewBag.ErrorEmail != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorEmail
                        </span>
                    }
                </p>

                <p>
                    <label>Confirmar Email:</label><br />
                    @Html.TextBoxFor(
                         model => model.Usuario.CONFIRMAR_EMAIL,
                         new
                         {
                             id = "txtConfirmarEmail",
                             type = "email",
                             placeholder = "Confirme el correo electrónico",
                             maxlength = "100",
                             autocomplete = "off"
                         })

                    <br />

                    @if (ViewBag.ErrorConfirmarEmail != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorConfirmarEmail
                        </span>
                    }

                </p>

                <p>
                    <label>Contraseña:</label><br />

                    @Html.PasswordFor(
                        model => model.Usuario.PASSWORD,
                        new
                        {
                            id = "txtPassword",
                            placeholder = "Ingrese la contraseña",
                            maxlength = "50",
                            autocomplete = "new-password"
                        })

                    <br />

                    @if (ViewBag.ErrorPassword != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorPassword
                        </span>
                    }

                </p>

                <p>
                    <label>Confirmar Contraseña:</label><br />

                    @Html.PasswordFor(
                        model => model.Usuario.CONFIRMAR_PASSWORD,
                        new
                        {
                            id = "txtConfirmarPassword",
                            placeholder = "Confirme la contraseña",
                            maxlength = "50",
                            autocomplete = "new-password"
                        })

                    <br />

                    @if (ViewBag.ErrorConfirmarPassword != null)
                    {
                        <span style="color:red;">
                            @ViewBag.ErrorConfirmarPassword
                        </span>
                    }

                </p>

                <!-- Botones del CRUD-->

                <button type="submit"
                        name="accion"
                        value="Registrar">
                    Registrar
                </button>
                <br />

                <br />
                <button type="submit"
                        name="accion"
                        value="Actualizar">
                    Actualizar
                </button>
                <br />

                @if (ViewBag.MensajeActualizar != null)
                {
                    <span style="color:blue;">
                        @ViewBag.MensajeActualizar
                    </span>
                }

                <br />
                <button type="submit"
                        name="accion"
                        value="Eliminar">
                    Eliminar
                </button>
                <br />

                <br />
                <button type="submit"
                        name="accion"
                        value="Limpiar">
                    Limpiar
                </button>

            </td>


            <!-- Información y tabla-->

            <td style="vertical-align:top;">

                <h3>Movimiento realizado</h3>

                <p>
                    <strong>Movimiento:</strong> _____________________
                    &nbsp;&nbsp;&nbsp;

                    <strong>Fecha:</strong> ____________
                    &nbsp;&nbsp;&nbsp;

                    <strong>Hora:</strong> ____________
                </p>

                <hr />

                <h3>Usuarios Registrados</h3>

                <table border="1" style="width:100%; text-align:center;">

                    <!-- Encabezado de la tabla -->
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Apellido P.</th>
                        <th>Apellido M.</th>
                        <th>Edad</th>
                        <th>Género</th>
                        <th>Email</th>
                    </tr>

                    <!-- Registros obtenidos de la base de datos-->
                    @foreach (var item in Model.ListaUsuarios)
                    {
                        <tr>
                            <td>@item.ID_USUARIO</td>
                            <td>@item.NOMBRE</td>
                            <td>@item.APELLIDO_PATERNO</td>
                            <td>@item.APELLIDO_MATERNO</td>
                            <td>@item.EDAD</td>
                            <td>@item.GENERO</td>
                            <td>@item.EMAIL</td>
                        </tr>
                    }

                </table>

            </td>

        </tr>

    </table>

}
