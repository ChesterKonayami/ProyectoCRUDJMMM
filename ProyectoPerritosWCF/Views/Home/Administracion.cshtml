@model ProyectoPerritosWCF.Models.AdministracionViewModel
@{
    ViewBag.Title = "Administración";
}

<!-- ========================================= -->
<!-- Panel de Administración                   -->
<!-- Proyecto CRUD JMMM                        -->
<!-- ========================================= -->

<h2>Panel de Administración de Usuarios</h2>

<hr />

@using (Html.BeginForm(
    "Administracion",
    "Home",
    FormMethod.Post))
{

    <table style="width:100%;">

        <tr>

            <!-- ========================================= -->
            <!-- Formulario CRUD                           -->
            <!-- ========================================= -->

            <td style="width:40%; vertical-align:top;">

                <h3>Formulario de Usuario</h3>

                <p>
                <p>
                    <label>ID:</label><br />

                    @Html.TextBoxFor(model => model.Usuario.ID_USUARIO)

                    <button type="submit"
                            name="accion"
                            value="Consultar">
                        Consultar
                    </button>

                </p>


                <p>
                    <label>Nombre:</label><br />

                    @Html.TextBoxFor(model => model.Usuario.NOMBRE)

                </p>

                <p>
                    <label>Apellido Paterno:</label><br />

                    @Html.TextBoxFor(model => model.Usuario.APELLIDO_PATERNO)

                </p>

                <p>
                    <label>Apellido Materno:</label><br />
                    @Html.TextBoxFor(model => model.Usuario.APELLIDO_MATERNO)
                </p>

                <p>
                    <label>Edad:</label><br />
                    @Html.TextBoxFor(model => model.Usuario.EDAD)
                </p>

                <p>
                    <label>Género:</label><br />
                    @Html.TextBoxFor(model => model.Usuario.GENERO)
                </p>

                <p>
                    <label>Email:</label><br />
                    @Html.TextBoxFor(model => model.Usuario.EMAIL)
                </p>

                <p>
                    <label>Confirmación de Email:</label><br />
                    <input type="text" />
                </p>

                <p>
                    <label>Contraseña:</label><br />
                    @Html.TextBoxFor(model => model.Usuario.PASSWORD)
                </p>

                <p>
                    <label>Confirmación de Contraseña:</label><br />
                    <input type="password" />
                </p>

                <br />

                <button>Guardar</button>
                <button>Actualizar</button>
                <button>Eliminar</button>
                <button>Limpiar</button>

            </td>


            <!-- ========================================= -->
            <!-- Información y tabla                       -->
            <!-- ========================================= -->

            <td style="vertical-align:top;">

                <h3>Movimiento realizado</h3>

                <p>
                    <strong>Movimiento:</strong> _____________________
                    &nbsp;&nbsp;&nbsp;

                    <strong>Fecha:</strong> ____________
                    &nbsp;&nbsp;&nbsp;

                    <strong>Hora:</strong> ____________
                </p>

                <hr />

                <h3>Usuarios Registrados</h3>

                <table border="1" style="width:100%; text-align:center;">

                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Apellido P.</th>
                        <th>Apellido M.</th>
                        <th>Edad</th>
                        <th>Género</th>
                        <th>Email</th>
                    </tr>

                    @foreach (var item in Model.ListaUsuarios)
                    {
                        <tr>
                            <td>@item.ID_USUARIO</td>
                            <td>@item.NOMBRE</td>
                            <td>@item.APELLIDO_PATERNO</td>
                            <td>@item.APELLIDO_MATERNO</td>
                            <td>@item.EDAD</td>
                            <td>@item.GENERO</td>
                            <td>@item.EMAIL</td>
                        </tr>
                    }

                </table>

            </td>

        </tr>

    </table>
}
